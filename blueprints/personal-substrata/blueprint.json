{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Personal Blog",
		"description": "A blog site created with the Substrata theme, see https://substratademo.wordpress.com/?demo",
		"author": "WordPress.com",
		"categories": ["Website", "Personal", "Blog"]
	},
	"login": true,
	"siteOptions": {
		"blogname": "Substrata"
	},
	"steps": [
		{
			"step": "resetData"
		},
		{
			"step": "installTheme",
			"themeData": {
				"resource": "bundled",
				"path": "./substrata.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "bundled",
				"path": "./content.xml"
			}
		}
	]
}
