{
  	"meta": {
		"title": "Weather Shortcode Plugin",
		"description": "A blueprint to connetc weather API and show data as shortcode on a WordPress site.",
		"author": "muryamsultana"
	},
  "steps": [
    {
      "step": "mkdir",
      "path": "/wordpress/wp-content/plugins/weather-app"
    },
     {
      "step": "writeFile",
      "path": "/wordpress/wp-content/plugins/weather-app/weather.php",
      "data": {
        "resource": "bundled",
        "path": "/plugin/weather.php"
      }
    },
    {
      "step": "activatePlugin",
      "pluginPath": "weather-app/weather.php"
    },
    {
      "step": "wp-cli",
           "command": "wp post create --post_title='The Weather Today' --post_content='<!-- wp:columns {\"align\":\"wide\"} --><div class=\"wp-block-columns alignwide\"><!-- wp:column {\"className\":\"is-style-section-1\",\"style\":\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|30\",\"bottom\":\"var:preset|spacing|30\",\"left\":\"var:preset|spacing|30\",\"right\":\"var:preset|spacing|30\"}},\"color\":{\"background\":\"#ffee594f\"},\"border\":{\"radius\":\"8px\"}}} --><div class=\"wp-block-column is-style-section-1 has-background\" style=\"border-radius:8px;background-color:#ffee594f;padding-top:var(--wp--preset--spacing--30);padding-right:var(--wp--preset--spacing--30);padding-bottom:var(--wp--preset--spacing--30);padding-left:var(--wp--preset--spacing--30)\"><!-- wp:paragraph --><p>Check out the current weather conditions in London below. Make sure to dress accordingly!</p><!-- /wp:paragraph --><!-- wp:shortcode -->[weather]<!-- /wp:shortcode --></div><!-- /wp:column --><!-- wp:column {\"style\":{\"color\":{\"background\":\"#ffee594f\"},\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|30\",\"bottom\":\"var:preset|spacing|30\",\"left\":\"var:preset|spacing|30\",\"right\":\"var:preset|spacing|30\"}},\"border\":{\"radius\":\"8px\"}}} --><div class=\"wp-block-column has-background\" style=\"border-radius:8px;background-color:#ffee594f;padding-top:var(--wp--preset--spacing--30);padding-right:var(--wp--preset--spacing--30);padding-bottom:var(--wp--preset--spacing--30);padding-left:var(--wp--preset--spacing--30)\"><!-- wp:paragraph --><p>You can use this shortcode for any city, e.g., adding the property <code>city=Islamabad</code>.</p><!-- /wp:paragraph --><!-- wp:shortcode -->[weather city=Islamabad]<!-- /wp:shortcode --></div><!-- /wp:column --></div><!-- /wp:columns -->' --post_status='publish'"
    },
    {
      "step": "login",
      "username": "admin",
      "password": "password"
    }
  ],
  "siteOptions": {
    "permalink_structure": "/%postname%/"
  },
  "landingPage": "/the-weather-today"
}
