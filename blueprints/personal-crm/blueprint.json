{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Personal CRM",
		"description": "Manage your contacts and relationships directly from WordPress",
		"author": "Alex Kirk",
		"categories": [
			"Apps",
			"Productivity"
		]
	},
	"landingPage": "/crm/welcome",
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/akirk/personal-crm",
				"ref": "dist/main",
				"refType": "branch"
			},
			"options": {
				"activate": true,
				"targetFolderName": "personal-crm"
			}
		},
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/akirk/keeping-contact",
				"ref": "dist/main",
				"refType": "branch"
			},
			"options": {
				"activate": true,
				"targetFolderName": "keeping-contact"
			}
		}
	]
}
