{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Theme Tester",
		"description": "Blueprint example to add content and plugins to explore a theme",
		"author": "bph",
		"categories": ["themes", "content"]
	},
	"preferredVersions": {
		"php": "8.3",
		"wp": "beta"
	},
	"login": true,
	"plugins": ["create-block-theme"],
	"steps": [
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://github.com/wpaccessibility/a11y-theme-unit-test/blob/master/a11y-theme-unit-test-data.xml"
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "url",
				"url": "https://github.com/WordPress/theme-test-data/blob/master/themeunittestdata.wordpress.xml"
			}
		},
		{
			"step": "installTheme",
			"themeData": {
				"resource": "wordpress.org/themes",
				"slug": "twentytwentyfive"
			},
			"options": {
				"activate": true
			}
		}
	]
}
