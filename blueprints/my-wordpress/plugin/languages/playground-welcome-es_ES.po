#: playground-welcome.php
msgid "Welcome"
msgstr "Bienvenida"

#: playground-welcome.php
msgid "👋 Welcome to Your WordPress"
msgstr "👋 Te damos la bienvenida a tu WordPress"

#: playground-welcome.php
msgid "Welcome to Your WordPress"
msgstr "Este es tu WordPress"

#: playground-welcome.php
msgid ""
"This is a private WordPress that's free and needs no account. It's stored in "
"your browser and will be here when you come back."
msgstr ""
"Este es un sitio WordPress privado, gratuito y que no requiere crear una "
"cuenta. Se guarda en tu navegador y seguirá aquí cuando vuelvas."

#: playground-welcome.php
msgid "What's your name?"
msgstr "¿Cómo te llamas?"

#: playground-welcome.php
msgid "Import content from a website"
msgstr "Importar contenido de un sitio web"

#: playground-welcome.php
msgid "Website URL"
msgstr "URL del Sitio Web"

#: playground-welcome.php
msgid "Enter a site URL and we'll find and import its RSS feed."
msgstr ""
"Introduce la URL de una página web y nosotros buscaremos e importaremos su "
"feed RSS."

#: playground-welcome.php
msgid "Maximum posts to import"
msgstr "Máximo de entradas que importar"

#: playground-welcome.php
msgid "5 posts"
msgstr "5 entradas"

#: playground-welcome.php
msgid "10 posts"
msgstr "10 entradas"

#: playground-welcome.php
msgid "20 posts"
msgstr "20 entradas"

#: playground-welcome.php
msgid "50 posts"
msgstr "50 entradas"

#: playground-welcome.php
msgid "Continue"
msgstr "Continuar"

#: playground-welcome.php
msgid "Importing..."
msgstr "Importando..."

#: playground-welcome.php
msgid "Not now"
msgstr "Ahora no"

#: playground-welcome.php
msgid "Security check failed."
msgstr "La comprobación de seguridad ha fallado."

#: playground-welcome.php
msgid "Permission denied."
msgstr "Permiso denegado."

#. translators: %s: user's display name
#: playground-welcome.php
msgid "%s's WordPress"
msgstr "El WordPress de %s"

#. translators: %s: user's display name
#: playground-welcome.php
msgid "Name updated to \"%s\""
msgstr "El nombre se ha actualizado a «%s»"

#: playground-welcome.php
msgid "Redirecting to your site..."
msgstr "Redirigiendo a tu sitio web..."

#: playground-welcome.php
msgid "Setup complete! Redirecting to your site..."
msgstr "¡Configuración completada! Redirigiendo a tu sitio web..."

#. translators: %s: error message
#: playground-welcome.php
msgid "Could not fetch feed: %s"
msgstr "No se ha podido recuperar el feed: %s"

#: playground-welcome.php
msgid "No items found in the feed."
msgstr "No se han encontrado entradas en el feed."

#. translators: %s: URL of the original article
#: playground-welcome.php
msgid "Originally published at <a href=\"%1$s\">%2$s</a>"
msgstr "Publicado originalmente en <a href=\"%1$s\">%2$s</a>"

#. translators: %d: number of imported posts
#: playground-welcome.php
msgid "Imported %d post from feed"
msgid_plural "Imported %d posts from feed"
msgstr[0] "%d entrada importada del feed"
msgstr[1] "%d entradas importadas del feed"
