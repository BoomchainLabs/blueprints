#: playground-welcome.php
msgid "Welcome"
msgstr "Witaj"

#: playground-welcome.php
msgid "The Vision"
msgstr "Wizja"

#: playground-welcome.php
msgid "👋 Welcome to Your WordPress"
msgstr "👋 Witaj w swoim WordPressie"

#: playground-welcome.php
msgid "Welcome to Your WordPress"
msgstr "Witaj w swoim WordPressie"

#: playground-welcome.php
msgid "This is a private WordPress that's free and needs no account. It's stored in your browser and will be here when you come back."
msgstr "To prywatny WordPress, który jest darmowy i nie wymaga konta. Jest przechowywany w Twojej przeglądarce i będzie tu, gdy wrócisz."

#: playground-welcome.php
msgid "What's your name?"
msgstr "Jak masz na imię?"

#: playground-welcome.php
msgid "Import content from a website"
msgstr "Importuj treści ze strony internetowej"

#: playground-welcome.php
msgid "Website URL"
msgstr "Adres strony"

#: playground-welcome.php
msgid "Enter a site URL and we'll find and import its RSS feed."
msgstr "Wpisz adres strony, a znajdziemy i zaimportujemy jej kanał RSS."

#: playground-welcome.php
msgid "Maximum posts to import"
msgstr "Maksymalna liczba wpisów do importu"

#: playground-welcome.php
msgid "5 posts"
msgstr "5 wpisów"

#: playground-welcome.php
msgid "10 posts"
msgstr "10 wpisów"

#: playground-welcome.php
msgid "20 posts"
msgstr "20 wpisów"

#: playground-welcome.php
msgid "50 posts"
msgstr "50 wpisów"

#: playground-welcome.php
msgid "Continue"
msgstr "Kontynuuj"

#: playground-welcome.php
msgid "Importing..."
msgstr "Importowanie..."

#: playground-welcome.php
msgid "Not now"
msgstr "Nie teraz"

#: playground-welcome.php
msgid "Security check failed."
msgstr "Weryfikacja bezpieczeństwa nie powiodła się."

#: playground-welcome.php
msgid "Permission denied."
msgstr "Brak uprawnień."

#. translators: %s: user's display name
#: playground-welcome.php
msgid "%s's WordPress"
msgstr "WordPress użytkownika %s"

#. translators: %s: user's display name
#: playground-welcome.php
msgid "Name updated to \"%s\""
msgstr "Imię zmienione na \"%s\""

#: playground-welcome.php
msgid "Redirecting to your site..."
msgstr "Przekierowanie na Twoją stronę..."

#: playground-welcome.php
msgid "Setup complete! Redirecting to your site..."
msgstr "Konfiguracja zakończona! Przekierowanie na Twoją stronę..."

#. translators: %s: error message
#: playground-welcome.php
msgid "Could not fetch feed: %s"
msgstr "Nie udało się pobrać kanału: %s"

#: playground-welcome.php
msgid "No items found in the feed."
msgstr "Nie znaleziono wpisów w kanale."

#. translators: %s: URL of the original article
#: playground-welcome.php
msgid "Originally published at <a href=\"%1$s\">%2$s</a>"
msgstr "Pierwotnie opublikowano na <a href=\"%1$s\">%2$s</a>"

#. translators: %d: number of imported posts
#: playground-welcome.php
msgid "Imported %d post from feed"
msgid_plural "Imported %d posts from feed"
msgstr[0] "Zaimportowano %d wpis z kanału"
msgstr[1] "Zaimportowano %d wpisy z kanału"
msgstr[2] "Zaimportowano %d wpisów z kanału"
