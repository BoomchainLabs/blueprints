{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Photography Portfolio",
		"description": "A photography portfolio created with the Grammer theme.",
		"author": "WordPress.com",
		"categories": ["Website", "Personal", "Photography"]
	},
	"login": true,
	"siteOptions": {
		"blogname": "Grammer"
	},
	"steps": [
		{
			"step": "resetData"
		},
		{
			"step": "installTheme",
			"themeData": {
				"resource": "bundled",
				"path": "./grammer.zip"
			},
			"options": {
				"activate": true
			}
		},
		{
			"step": "importWxr",
			"file": {
				"resource": "bundled",
				"path": "./content.xml"
			}
		}
	]
}
