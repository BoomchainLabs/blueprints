{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "meta": {
    "title": "Theme Review Environment",
    "author": "supernovia",
    "description": "Helps new theme reviewers get started faster by installing Theme Check and other recommended plugins, enabling WP-CLI, and turning on debug logging.",
    "categories": [
      "Contributor",
      "Test Environment"
    ]
  },
  "login": true,
  "landingPage": "wp-admin/theme-install.php",
  "siteOptions": {
    "blogname": "Theme Review Environment"
  },
  "extraLibraries": [
    "wp-cli"
  ],
  "steps": [
    {
      "step": "defineWpConfigConsts",
      "consts": {
        "WP_DEBUG": true,
        "WP_DEBUG_LOG": true,
        "WP_DEBUG_DISPLAY": false
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "theme-check"
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "query-monitor"
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "log-deprecated-notices"
      }
    },
    {
      "step": "importWxr",
      "file": {
        "resource": "bundled",
        "path": "./themeunittestdata.wordpress.xml"
      }
		}
  ]
}
