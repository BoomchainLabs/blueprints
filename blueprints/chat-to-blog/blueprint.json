{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"meta": {
		"title": "Chat to Blog",
		"description": "Import media from Beeper chats and create blog posts. Requires Beeper Desktop running.",
		"author": "Alex Kirk",
		"categories": ["Apps", "Media"]
	},
	"landingPage": "/wp-admin/admin.php?page=chat-to-blog",
	"steps": [
		{
			"step": "installPlugin",
			"pluginData": {
				"resource": "git:directory",
				"url": "https://github.com/akirk/chat-to-blog",
				"ref": "dist/main",
				"refType": "branch"
			},
			"options": {
				"activate": true,
				"targetFolderName": "chat-to-blog"
			}
		}
	]
}
